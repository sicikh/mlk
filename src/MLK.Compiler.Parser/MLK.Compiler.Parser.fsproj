<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="TokenSource.fs" />
        <Compile Include="Diagnostics.fs" />
        <Compile Include="TreeSink.fs" />
        <FsLex Include="Lex.fsl">
            <OtherFlags>--module MLK.Compiler.Parser.Lex --unicode --internal</OtherFlags>
        </FsLex>
        <Compile Include="Lex.fsi"/>
        <Compile Include="Lex.fs"/>
        <Compile Include="Lexer.fs"/>
        <Compile Include="IParsec.fs"/>
        <Compile Include="Parser.fsi" />
        <Compile Include="Parser.fs" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\MLK.Compiler.Fusca\MLK.Compiler.Fusca.fsproj"/>
        <ProjectReference Include="..\MLK.Compiler.Syntax\MLK.Compiler.Syntax.fsproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="FsLexYacc" Version="11.3.0"/>
    </ItemGroup>

</Project>
